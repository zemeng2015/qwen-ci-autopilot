# Qwen Cloud / Alibaba Cloud Model Studio
# Create this in Qwen Cloud, then keep it out of git.
DASHSCOPE_API_KEY=

# Qwen Cloud defaults from the official quickstart.
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.7-plus

# Local server
PORT=8787

# Alibaba deployment metadata shown in /api/health.
ALIBABA_CLOUD_REGION=us-east-1
ALIBABA_CLOUD_SERVICE=qwen-ci-autopilot-api
